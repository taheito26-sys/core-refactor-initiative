# ── WebRTC / Signaling ─────────────────────────────────────────────────────────
#
# VITE_SIGNAL_RELAY_URLS
#   Comma-separated WebSocket relay URLs the frontend connects to for signaling.
#   The deployed Supabase signaling-relay function is the primary relay.
#   Authentication uses an HMAC token issued by the call-session edge function;
#   RELAY_HMAC_SECRET must be set identically in both edge function secrets
#   (call-session and signaling-relay) via the Supabase dashboard.
#   Also set SIGNALING_RELAY_URL=<same URL> in call-session's edge function
#   secrets so the edge function returns this URL to the frontend.
#
VITE_SIGNAL_RELAY_URLS="wss://dozmqtzlinfqjrropipb.supabase.co/functions/v1/signaling-relay"

# ── TURN Server (required for symmetric-NAT / CGNAT peers) ────────────────────
#
# Without TURN, peers on carrier-grade NAT or corporate symmetric NAT cannot
# establish direct P2P media connections — they fall through to "failed" ICE
# state, which is why calls only work on networks where VPN simplifies NAT
# traversal to Full-Cone or Restricted-Cone.
#
# The call-session edge function also reads TURN_URL / TURN_USERNAME /
# TURN_CREDENTIAL from Supabase edge function secrets (or CLOUDFLARE_TURN_TOKEN
# + CLOUDFLARE_TURN_KEY_ID for dynamic Cloudflare TURN) and returns ICE config
# to the frontend.  The VITE_TURN_* vars below are used as a client-side
# fallback when the edge function call itself fails.
#
# Replace these with your own coturn / Cloudflare / Twilio / metered.ca
# TURN credentials.  All three transport variants (UDP 3478, TCP 443, TLS 443)
# are built automatically by resilient-ice.ts from a single host entry.
#
VITE_TURN_URL="turn:<your-turn-host>:3478"
VITE_TURN_USERNAME="<your-turn-username>"
VITE_TURN_CREDENTIAL="<your-turn-credential>"
